"35">- media</t><t w="32">一韻瞪DI吕</t><t w="32">一韻瞪DI涯</t><t w="32">一me DI吕</t><t w="32">一me DI涯</t><t w="32">一韻瞪dia</t><t w="32">一韻瞪DI启</t></item><item x="334" y="402" w="53" h="14"><t w="63">body＂＞</t><t w="32">bo Dy</t><t w="32">bo諺又</t><t w="31">bo諺瑟</t><t w="31">bo諺贺</t><t w="31">bo諺瀑</t><t w="31">bo遜又</t><t w="31">bo遜瑟</t><t w="30">bo遜贺</t></item><item x="388" y="400" w="72" h="15"><t w="49">联系我们</t><t w="35">我们</t><t w="34">殴系我们</t><t w="34">眩系我们</t><t w="33">联系哉们</t><t w="33">阪系我们</t><t w="32">联系载们</t><t w="32">联宗我们</t><t w="32">睬系我们</t><t w="30">联系裁们</t></item><item x="470" y="402" w="6" h="12"><t w="34">/</t><t w="29">1</t></item><item x="479" y="402" w="25" h="10"><t w="34">di腿</t><t w="34">di狱</t><t w="34">di魅</t><t w="33">div</t><t w="33">di谜</t><t w="29">諺IV</t><t w="27">且IV</t><t w="26">兰IV</t><t w="26">譜IV</t><t w="26">諺元腿</t></item><item x="507" y="404" w="6" h="9"><t w="31">算</t><t w="30">慷</t></item><item x="524" y="402" w="6" h="12"><t w="34">/</t><t w="29">1</t></item><item x="533" y="406" w="6" h="6"><t w="37">吕</t><t w="36">日</t><t w="35">紐</t><t w="35">启</t></item><item x="543" y="404" w="6" h="9"><t w="30">算</t><t w="30">慷</t></item><item x="560" y="402" w="33" h="12"><t w="34">/ LI &gt;</t><t w="34">/ II &gt;</t><t w="32">1 LI &gt;</t><t w="31">1 II &gt;</t><t w="31">/ 1元&gt;</t><t w="31">/ 1兄&gt;</t><t w="31">/ 1觅&gt;</t><t w="31">/ 1孚&gt;</t><t w="31">11元&gt;</t><t w="31">11兄&gt;</t></item><item x="29" y="421" w="15" h="12"><t w="32">&lt; 1</t><t w="32">《 1</t><t w="28">钉</t><t w="28">似</t><t w="28">鈕</t><t w="27">衍</t></item><item x="48" y="421" w="24" h="11"><t w="34">ul &gt;</t><t w="33">UI &gt;</t><t w="30">誠1 &gt;</t><t w="30">档1 &gt;</t><t w="30">肋1 &gt;</t><t w="28">蹦1 &gt;</t></item></recoIndex>
]]></recognition><resource-attributes><source-url>file://C:\Users\Administrator\Pictures\7.PNG</source-url><file-name>7.PNG</file-name></resource-attributes></resource></note><note><title>Git的使用</title><content><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd">

<en-note><div>&nbsp; <font style="font-size: 24pt;"><span style="font-size: 24pt; font-weight: bold;">&nbsp;Git的使用</span></font></div><div>&nbsp; &nbsp; &nbsp;&nbsp;</div><div>&nbsp; &nbsp; &nbsp; &nbsp;1.什么是Git?</div><div>Git是一款源代码管理工具(版本控制工具),我们写的代码需要使用Git进行管理.</div><div><br/></div><div>&nbsp;&nbsp; &nbsp;&nbsp; &nbsp;2.&nbsp;我们写的代码需要进行管理吗?</div><div>答: 有必要,因为人工的去处理不同的版本,做相应的备份会很麻烦,</div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div><span style="font-family: Monaco; font-size: 16pt; color: rgb(166, 0, 196); font-weight: bold;">Git的使用:</span></div><div><span style="font-family: Monaco; color: rgb(51, 51, 51); font-size: 10pt;">A. Git安装</span></div><div><span style="font-size: 10pt; font-family: Monaco; color: rgb(51, 51, 51);">B. Git初始化仓储(仓库)&nbsp;</span><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git init`</span></div><div><span style="font-family: Monaco; font-size: 10pt;">C. 配置使用者的用户名和邮箱</span></div><div><span style="font-family: Monaco; font-size: 10pt;">将创建的文件名备份到隐藏的文件夹 .git 下,</span></div><div><span style="font-family: Monaco; font-size: 10pt;">D. 在git中设置当前使用的用户是谁</span></div><div><span style="font-family: Monaco; font-size: 10pt;">命令:</span></div><div><span style="font-family: Monaco; font-size: 10pt;">&nbsp;</span> <span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">&nbsp; `</span><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">git&nbsp;&nbsp;config&nbsp;&nbsp;- - global&nbsp;&nbsp;&nbsp;user.name&nbsp;&nbsp;“用户名&quot;</span><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span></div><div><span style="font-family: Monaco; font-size: 10pt;">&nbsp; &nbsp;</span> <span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">git&nbsp;&nbsp;config&nbsp;&nbsp;- - global&nbsp;&nbsp;&nbsp;user.email&nbsp;&nbsp;”用户邮箱&quot;</span><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span></div><div><span style="font-family: Monaco; font-size: 10pt;">E. 将代码存储到 git 仓储</span></div><div><span style="font-family: Monaco; font-size: 10pt;">&nbsp; &nbsp; 放到仓储门口</span></div><div><span style="font-family: Monaco; font-size: 10pt;">&nbsp; &nbsp;</span> <span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git add .`</span></div><div><span style="font-family: Monaco; font-size: 10pt;">&nbsp; &nbsp; 把仓储门口的代码放到里面的房间去</span></div><div><span style="font-family: Monaco; font-size: 10pt;">&nbsp; &nbsp;</span> <span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git commit -m &quot;对本次存储的描述&quot;`</span></div></div><div><en-media hash="27d833482d5f970a505798baf2b5dd8a" type="image/png"/></div><div><br/></div><div><span style="font-size: 14pt; color: rgb(255, 0, 0);">工作区, 暂存区, 版本库</span></div><div><en-media hash="c4c9be8fa1ec7cb23c87003748a267e6" type="image/png"/></div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div>F. 查看当前代码有没有放到仓储中 <span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git status`</span></div><div>&nbsp;&nbsp;&nbsp;<span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git add ./`</span> 将所有修改的文件添加到大门口</div><div>&nbsp;&nbsp;&nbsp;<span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git commit --all -m &quot;一些说明&quot;`</span> 一次性提交所有的版本库信息到仓储</div><div>G. .gitignore 在这个文件中设置要被忽略的文件和目录,被忽略的文件不会被提交到仓储中去</div></div><div><en-media hash="8fb4fcbf657e902b9b2cc02f7b60dc46" type="image/png"/></div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div><span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span><span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold; font-family: Monaco;">git log</span> <span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span> 查看历史提交的日志</div><div><span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span><span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold; font-family: Monaco;">git log --oneline</span> <span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span> 一行显示</div><div><span style="font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`git reset --hard[版本号]`</span> 可以精确的返回到某一次提交的状态</div><div><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span><span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">git&nbsp;&nbsp;reflog</span> <span style="font-family: Monaco; font-size: 11pt; color: rgb(255, 0, 0); font-weight: bold;">`</span><span style="font-family: Monaco; font-size: 9pt; color: rgb(51, 51, 51);">&nbsp; 每一次切换版本的记录,可以看到所以提交的版本号</span></div></div><div><en-media hash="0fcc9d1ad9db29bfa910b3db25dd64cb" type="image/png"/></div><div><br/></div><div><font style="font-size: 14pt;"><span style="font-size: 14pt; color: rgb(118, 0, 216); font-weight: bold;">分支:</span></font></div><div>默认只有一个主分支 master</div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div><span style="font-family: Monaco;"><font style="color: rgb(51, 51, 51); font-size: 10pt;">1) 创建分支&nbsp;</font> <font color="#FF0000" style="font-size: 11pt;"><b>`git branch dev`</b></font></span></div><div><font style="font-size: 10pt;">&nbsp; 创建了dev分支</font></div><div><font style="font-size: 10pt;">&nbsp; 在刚创建时,dev分支的东西和master分支里的东西是一样的</font></div><div><font style="font-size: 10pt;">2) 切换分支</font> <font color="#FF0000" style="font-size: 11pt;"><b>`git checkout dev`</b></font></div><div><font style="font-size: 10pt;">&nbsp; &nbsp;切换到指定的分支,这里切换到名为dev的分支</font></div><div><font><span style="font-size: 10pt;">&nbsp; &nbsp;</span><font color="#FF0000" style="font-size: 11pt;"><b>`git branch`</b></font><span style="font-size: 10pt;">可以查看当前有哪些分支</span></font></div><div><font style="font-size: 10pt;">3) 合并分支</font> <font color="#FF0000" style="font-size: 11pt;"><b>`git merge dev`</b></font></div><div><font style="font-size: 10pt;">&nbsp; &nbsp;合并分支内容,把当前分支与指定的分支(dev)进行合并</font></div><div><font style="font-size: 10pt;">&nbsp; &nbsp;当前分支是指`git branch`命令输出的前面有*号的分支</font></div></div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div>1) 提交代码 github (当做git服务器来用)</div><div>&nbsp; <font color="#FF0000" style="font-size: 11pt;"><b>&nbsp;`git push [地址] master`</b></font>&nbsp;</div><div>&nbsp; &nbsp;会把当前分支的内容上传到远程的master分支上</div><div>2) 下载github上的代码</div><div>&nbsp; &nbsp;<font color="#FF0000" style="font-size: 11pt;"><b>`git pull [地址] master`</b></font></div><div>&nbsp; &nbsp;会把远程分支的数据得到(注意: 本地需要初创一个仓储)</div><div>3) <font color="#FF0000" style="font-size: 11pt;"><b>`git clone [地址]`</b></font></div><div>&nbsp; &nbsp;会得到远程仓储相同的数据,如果多次执行会覆盖本地内容</div></div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div><span style="color: rgb(0, 0, 0); font-family: 微软雅黑; font-size: medium; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px;">1. 通过 ssh 方式上传代码:</span></div><div><span style="color: rgb(0, 0, 0); font-family: 微软雅黑; font-size: medium; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px;">&nbsp; &nbsp;</span><span style="font-family: 微软雅黑; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px;"><font color="#3665EE" style="font-size: 11pt;"><b>`ssh-keygen&nbsp;&nbsp;-t&nbsp;&nbsp;rsa&nbsp;&nbsp;-C&nbsp;&nbsp;“github账号邮箱&quot;`</b></font></span></div><div><span style="font-family: 微软雅黑; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px;"><font color="#3665EE" style="font-size: 11pt;"><b><span>&nbsp; &nbsp; 会在c: users/administrator/.ssh中生成<span style="font-weight: bold; font-size: 11pt; color: rgb(54, 101, 238);">id_rsa.pub文件将秘钥拷贝到github中,如下图:&nbsp;</span></span></b></font></span></div></div><div><en-media hash="08d722c69705a5cfc76a2eb5589c36d2" type="image/png"/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div>2. 重新创建一个项目,拷贝 ssh 地址</div><div>3. 上传:</div><div>&nbsp; <font color="#FF0000" style="font-size: 11pt;"><b>`git push [地址] master`</b></font><br/></div></div><div><br/></div><div style="box-sizing: border-box; padding: 8px; font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px; color: rgb(51, 51, 51); border-radius: 4px; background-color: rgb(251, 250, 248); border: 1px solid rgba(0, 0, 0, 0.15);-en-codeblock:true;"><div><b><font style="font-size: 10pt;">提交代码出现冲突时:</font></b></div><div><span><b><font style="font-size: 10pt;">&nbsp;&nbsp; &nbsp;<span style="font-family: Monaco; color: rgb(51, 51, 51);">提交代码出现冲突，就将代码拉下来&nbsp;&nbsp;git pull 地址 master</span></font></b></span></div><div><span style="font-family: Monaco; color: rgb(51, 51, 51);"><b><font style="font-size: 10pt;"><span>&nbsp;&nbsp; &nbsp;</span><span>&nbsp;&nbsp; &nbsp;</span>打开文件，将冲突的删除，再输入git fix</font></b></span></div><div><span style="font-family: Monaco; color: rgb(51, 51, 51);"><b><font style="font-size: 10pt;"><span>&nbsp;&nbsp; &nbsp;</span><span>&nbsp;&nbsp; &nbsp;</span>然后再将文件push上去&nbsp;&nbsp;&nbsp;git push 地址 master</font></b></span></div><div><span style="font-family: Monaco; color: rgb(51, 51, 51);"><b><font style="font-size: 10pt;">&nbsp;&nbsp; &nbsp;&nbsp;&nbsp; &nbsp;Ctrl+c 可以重新输入</font></b></span></div></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div></en-note>]]></content><created>20180105T003323Z</created><updated>20180105T110109Z</updated><note-attributes><author>1501627915@qq.com</author><source>desktop.win</source><source-application>evernote.win32</source-application></note-attributes><resource><data encoding="base64">
